#!/bin/bash
# Install STT as a per-user LaunchAgent (runs in the user's login session, NOT a
# root LaunchDaemon). The thin bootstrapper needs the real user session: the
# setup GUI, the microphone TCC consent prompt, and ~/.stt all require it.
set -e

chmod +x /Applications/STT.app/Contents/MacOS/STT || true

# The pkg postinstall runs as root — resolve the actual logged-in user.
CONSOLE_USER="$(stat -f%Su /dev/console 2>/dev/null || echo '')"
if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ] || [ "$CONSOLE_USER" = "loginwindow" ]; then
    echo "[STT] No console user; skipping LaunchAgent install (open STT.app manually to set up)."
    exit 0
fi
CONSOLE_UID="$(id -u "$CONSOLE_USER")"
USER_HOME="$(dscl . -read /Users/"$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
[ -n "$USER_HOME" ] || USER_HOME="/Users/$CONSOLE_USER"

AGENT_DIR="$USER_HOME/Library/LaunchAgents"
PLIST="$AGENT_DIR/com.stt.watchdog.plist"
LOG_DIR="$USER_HOME/.stt/logs"
mkdir -p "$AGENT_DIR" "$LOG_DIR"

cat > "$PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stt.watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/STT.app/Contents/MacOS/STT</string>
        <string>--headless</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>
    <key>StandardOutPath</key>
    <string>$LOG_DIR/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>$LOG_DIR/launchd.out.log</string>
</dict>
</plist>
PLIST_EOF

chown "$CONSOLE_USER":staff "$PLIST"
chown -R "$CONSOLE_USER":staff "$USER_HOME/.stt" 2>/dev/null || true

# Load into the user's GUI session so it starts now and at every login.
launchctl bootout "gui/$CONSOLE_UID" "$PLIST" 2>/dev/null || true
launchctl bootstrap "gui/$CONSOLE_UID" "$PLIST" 2>/dev/null \
    || launchctl asuser "$CONSOLE_UID" launchctl load -w "$PLIST" 2>/dev/null \
    || true

# ── Control window ───────────────────────────────────────────────────────────
# A second LaunchAgent opens the desktop control window (--monitor) at each login.
# It is a client of the headless daemon above: closing the window never stops the
# server, and it self-suppresses when watchdog.show_control_window is false.
GUI_PLIST="$AGENT_DIR/com.stt.gui.plist"
cat > "$GUI_PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stt.gui</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/STT.app/Contents/MacOS/STT</string>
        <string>--monitor</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>$LOG_DIR/launchd.gui.log</string>
    <key>StandardErrorPath</key>
    <string>$LOG_DIR/launchd.gui.log</string>
</dict>
</plist>
PLIST_EOF

chown "$CONSOLE_USER":staff "$GUI_PLIST"
launchctl bootout "gui/$CONSOLE_UID" "$GUI_PLIST" 2>/dev/null || true
# bootstrap with RunAtLoad=true already opens the control window now; a separate
# `open -a` would race it and pop a second, duplicate window, so don't add one.
launchctl bootstrap "gui/$CONSOLE_UID" "$GUI_PLIST" 2>/dev/null \
    || launchctl asuser "$CONSOLE_UID" launchctl load -w "$GUI_PLIST" 2>/dev/null \
    || true

echo "[STT] LaunchAgents installed for $CONSOLE_USER (daemon + control window)."
exit 0
